local function getEffectiveWPsNoTP(wps, offsets)
	local result = {}
	for i, wp in ipairs(wps) do
		if i ~= 2 then
			local off = offsets[i] or {x=0,y=0,z=0}
			result[#result+1] = {x=wp.x+off.x, y=wp.y+off.y, z=wp.z+off.z, freeze=wp.freeze}
		end
	end
	return result
end
