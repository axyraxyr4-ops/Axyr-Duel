	-- Table pour sauvegarder les positions des boutons flottants
	if not G.floatBtnPositions then G.floatBtnPositions = {} end

	-- Crée un bouton flottant indépendant, draggable par lui-même
	-- isToggle=false → chaque clic/touche déclenche l'action directement (pas d'état on/off persistant)
	local function makeFloatingBtn(startX, startY, label, keyName, colorAccent, onAction, isToggle)
		local isOn = false

		-- Charger position sauvegardée si disponible
		local savedPos = G.floatBtnPositions[label]
		local posX = savedPos and savedPos.x or startX
		local posY = savedPos and savedPos.y or startY

		-- Frame racine = le bouton entier, draggable
		local btn = Instance.new("Frame", gui)
		btn.Name = "FloatBtn_"..label
		btn.Size = UDim2.new(0, BTN_W + KB_W, 0, BTN_H)
		btn.Position = UDim2.new(0, posX, 0, posY)
		btn.BackgroundColor3 = Color3.fromRGB(12, 9, 22)
		btn.BorderSizePixel = 0
		btn.Active = true
		btn.ZIndex = 30
		addCorner(btn, 10)

		local stroke = Instance.new("UIStroke", btn)
		stroke.Color = C.BORDER
		stroke.Thickness = 1.5
		stroke.Transparency = 0.3

		-- Label
		local lblEl = Instance.new("TextLabel", btn)
		lblEl.Size = UDim2.new(1, -(KB_W + 12), 0, 26)
		lblEl.Position = UDim2.new(0, 12, 0, 9)
		lblEl.BackgroundTransparency = 1
		lblEl.Text = label
		lblEl.TextColor3 = C.WHITE
		lblEl.Font = Enum.Font.GothamBlack
		lblEl.TextSize = 16
		lblEl.TextXAlignment = Enum.TextXAlignment.Left
		lblEl.ZIndex = 31

		-- Pill toggle (visible seulement si isToggle)
		local pill = Instance.new("Frame", btn)
		pill.Size = UDim2.new(0, 40, 0, 20)
		pill.Position = UDim2.new(0, 12, 1, -28)
		pill.BackgroundColor3 = Color3.fromRGB(30, 20, 50)
		pill.BorderSizePixel = 0
		pill.ZIndex = 31
		pill.Visible = (isToggle ~= false)
		addCorner(pill, 10)

		local pillDot = Instance.new("Frame", pill)
		pillDot.Size = UDim2.new(0, 16, 0, 16)
		pillDot.Position = UDim2.new(0, 2, 0.5, -8)
		pillDot.BackgroundColor3 = C.DIM
		pillDot.BorderSizePixel = 0
		pillDot.ZIndex = 32
		addCorner(pillDot, 8)

		local statusLbl = Instance.new("TextLabel", btn)
		statusLbl.Size = UDim2.new(0, 36, 0, 18)
		statusLbl.Position = UDim2.new(0, 58, 1, -27)
		statusLbl.BackgroundTransparency = 1
		statusLbl.Text = (isToggle ~= false) and "OFF" or ""
		statusLbl.TextColor3 = Color3.fromRGB(90, 70, 120)
		statusLbl.Font = Enum.Font.GothamBlack
		statusLbl.TextSize = 12
		statusLbl.ZIndex = 31

		-- Séparateur vertical
		local sep = Instance.new("Frame", btn)
		sep.Size = UDim2.new(0, 1, 0.6, 0)
		sep.Position = UDim2.new(1, -KB_W, 0.2, 0)
		sep.BackgroundColor3 = C.BORDER
		sep.BorderSizePixel = 0
		sep.ZIndex = 31

		-- Keybind (label synchronisé avec KB table)
		local kbEl = Instance.new("TextLabel", btn)
		kbEl.Size = UDim2.new(0, KB_W, 1, 0)
		kbEl.Position = UDim2.new(1, -KB_W, 0, 0)
		kbEl.BackgroundTransparency = 1
		kbEl.Text = (keyName and KB[keyName]) and getKeyName(KB[keyName]) or "—"
		kbEl.TextColor3 = colorAccent
		kbEl.Font = Enum.Font.GothamBlack
		kbEl.TextSize = 20
		kbEl.TextXAlignment = Enum.TextXAlignment.Center
		kbEl.ZIndex = 31

		-- setVisual déclaré AVANT les connexions pour éviter le bug de scope
		local function setVisual(s)
			if isToggle == false then return end
			isOn = s
			btn.BackgroundColor3 = s and C.ON_BG or Color3.fromRGB(12, 9, 22)
			stroke.Color = s and colorAccent or C.BORDER
			stroke.Transparency = s and 0.05 or 0.3
			pill.BackgroundColor3 = s and colorAccent or Color3.fromRGB(30, 20, 50)
			pillDot.BackgroundColor3 = s and Color3.fromRGB(255,255,255) or C.DIM
			TS:Create(pillDot, TweenInfo.new(0.13), {
				Position = s and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)
			}):Play()
			statusLbl.Text = s and "ON" or "OFF"
			statusLbl.TextColor3 = s and C.GREEN or Color3.fromRGB(90,70,120)
			lblEl.TextColor3 = s and colorAccent or C.WHITE
		end

		-- Drag : click court = action, click long = drag
		local dragActive = false
		local dragOffX, dragOffY = 0, 0
		local moved = false

		btn.InputBegan:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
				moved = false
				dragOffX = inp.Position.X - btn.AbsolutePosition.X
				dragOffY = inp.Position.Y - btn.AbsolutePosition.Y
				dragActive = true
			end
		end)

		UIS.InputChanged:Connect(function(inp)
			if not dragActive then return end
			if G.btnLocked then dragActive = false; return end  -- cadenas actif = pas de drag
			if inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch then
				local dx = math.abs(inp.Position.X - (btn.AbsolutePosition.X + dragOffX))
				local dy = math.abs(inp.Position.Y - (btn.AbsolutePosition.Y + dragOffY))
				if dx > 4 or dy > 4 then moved = true end
				if moved then
					btn.Position = UDim2.new(0, inp.Position.X - dragOffX, 0, inp.Position.Y - dragOffY)
				end
			end
		end)

		UIS.InputEnded:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
				if dragActive then
					dragActive = false
					if moved then
						-- Sauvegarder la nouvelle position
						G.floatBtnPositions[label] = {
							x = math.floor(btn.AbsolutePosition.X),
							y = math.floor(btn.AbsolutePosition.Y)
						}
						saveConfig()
					else
						-- Clic = déclencher l'action
						if isToggle ~= false then
							isOn = not isOn
							setVisual(isOn)
							if onAction then onAction(isOn) end
						else
							-- Flash visuel
							btn.BackgroundColor3 = C.ON_BG
							stroke.Color = colorAccent; stroke.Transparency = 0.05
							task.delay(0.18, function()
								btn.BackgroundColor3 = Color3.fromRGB(12, 9, 22)
								stroke.Color = C.BORDER; stroke.Transparency = 0.3
							end)
							if onAction then onAction() end
						end
					end
				end
			end
		end)

		if keyName then G.allBadges[keyName] = kbEl end
		return setVisual
	end

	-- ============================================================
	-- Positions : boutons dans la zone encadrée sur la photo
	-- (zone centrale de l'écran, côté duel, autour de x=310..610)
	-- LX = colonne gauche dans la zone encadrée
	-- RX = colonne droite dans la zone encadrée
	-- Y0 = hauteur de départ (milieu écran)
	-- ============================================================
	local LX = 310                         -- colonne gauche zone encadrée
	local RX = 310 + BTN_W + KB_W + 10    -- colonne droite zone encadrée
	local Y0 = 320   -- y de départ (zone milieu-écran comme sur la photo)
	local YS = BTN_H + 8  -- espacement vertical

	-- ---- GAUCHE ----
	-- Photo : Track Player (haut), Float (milieu)
	local trackSideV = makeFloatingBtn(LX, Y0,           "TRACK PLAYER", "AutoTP",       C.ACCENT2, function(on)
		G_tpAutoEnabled = on
		task.spawn(function() refreshMyPlotSide() end)
		if G.tpAutoSetVisual then G.tpAutoSetVisual(on) end
	end, true)
	local floatSideV = makeFloatingBtn(LX, Y0 + YS,      "FLOAT",        "FloatToggle",  C.ACCENT2, function(on)
		G.floatEnabled = on
		if on then startFloat() else stopFloat() end
		if G.floatSetVisual then G.floatSetVisual(on) end
	end, true)
	-- ---- DROITE ----
	local tpDownSideV = makeFloatingBtn(RX, Y0,           "TP DOWN",      "TPDown",       C.ACCENT2, function()
		runTPDown()
	end, false)
	local dropSideV   = makeFloatingBtn(RX, Y0 + YS,      "DROP",         "DropBrainrot", C.ORANGE,  function()
		runDrop()
	end, false)
	local aplSideV    = makeFloatingBtn(RX, Y0 + 2*YS,    "AUTO LEFT",    "AutoPlayLeft", C.GREEN,   function(on)
		G.autoPlayLeftEnabled = on
		if on then
			if G.autoBatEnabled then disableAutoBat() end
			if G.autoPlayRightEnabled then
				stopAutoPlayRight(); G.autoPlayRightEnabled = false
				if G.autoPlayRightSetVisual then G.autoPlayRightSetVisual(false) end
			end
			startAutoPlayLeft()
		else stopAutoPlayLeft() end
		if G.autoPlayLeftSetVisual then G.autoPlayLeftSetVisual(on) end
	end, true)
	G.autoPlayLeftSideV = aplSideV

	local aprSideV    = makeFloatingBtn(RX, Y0 + 3*YS,    "AUTO RIGHT",   "AutoPlayRight",C.GREEN,   function(on)
		G.autoPlayRightEnabled = on
		if on then
			if G.autoBatEnabled then disableAutoBat() end
			if G.autoPlayLeftEnabled then
				stopAutoPlayLeft(); G.autoPlayLeftEnabled = false
				if G.autoPlayLeftSetVisual then G.autoPlayLeftSetVisual(false) end
			end
			startAutoPlayRight()
		else stopAutoPlayRight() end
		if G.autoPlayRightSetVisual then G.autoPlayRightSetVisual(on) end
	end, true)
	G.autoPlayRightSideV = aprSideV

	-- ======== SYNC avec visuals du menu principal ========
	local _oFloat = G.floatSetVisual
	G.floatSetVisual = function(s) if _oFloat then _oFloat(s) end; floatSideV(s) end

	local _oTP = G.tpAutoSetVisual
	G.tpAutoSetVisual = function(s) if _oTP then _oTP(s) end; trackSideV(s) end

	local _oAPL = G.autoPlayLeftSetVisual
	G.autoPlayLeftSetVisual = function(s) if _oAPL then _oAPL(s) end; aplSideV(s) end

	local _oAPR = G.autoPlayRightSetVisual
	G.autoPlayRightSetVisual = function(s) if _oAPR then _oAPR(s) end; aprSideV(s) end
end

-- ============================================================
-- WAYPOINT MARKERS
-- ============================================================
do
	local WP_COLORS = {Color3.fromRGB(80,180,255),Color3.fromRGB(100,255,120),Color3.fromRGB(255,220,50),Color3.fromRGB(255,80,160)}
	local wpFolder = Instance.new("Folder", workspace); wpFolder.Name = "AXYRDUEL_WaypointMarkers"
	local markers = {}
	local function clearMarkers()
		for _, p in ipairs(markers) do pcall(function() p:Destroy() end) end; markers = {}
	end
	local function makeMarker(x, y, z, color, label)
		local part = Instance.new("Part", wpFolder); part.Size = Vector3.new(1.8, 0.4, 1.8)
		part.Material = Enum.Material.Neon; part.Color = color
		part.Anchored = true; part.CanCollide = false; part.CastShadow = false; part.Transparency = 0.2
		part.CFrame = CFrame.new(x, y + 0.3, z)
		local bb = Instance.new("BillboardGui", part); bb.Size = UDim2.new(0,44,0,22)
		bb.StudsOffset = Vector3.new(0,1.5,0); bb.AlwaysOnTop = true
		local lbl = Instance.new("TextLabel", bb); lbl.Size = UDim2.new(1,0,1,0); lbl.BackgroundTransparency = 1
		lbl.Text = label; lbl.Font = Enum.Font.GothamBlack; lbl.TextSize = 15
		lbl.TextColor3 = color; lbl.TextStrokeTransparency = 0
		markers[#markers+1] = part
	end
	local function refreshMarkers()
		clearMarkers()
		local side = G_myPlotSide
		if side == "left" then
			for i, wp in ipairs(AP_Waypoints) do
				local off = AP_Offsets[i] or {x=0,y=0,z=0}
				makeMarker(wp.x+off.x, wp.y+off.y, wp.z+off.z, WP_COLORS[i], "L"..i)
			end
		elseif side == "right" then
			for i, wp in ipairs(APR_Waypoints) do
				local off = APR_Offsets[i] or {x=0,y=0,z=0}
				makeMarker(wp.x+off.x, wp.y+off.y, wp.z+off.z, WP_COLORS[i], "R"..i)
			end
		end
	end
	G.refreshWPMarkers = refreshMarkers
	if G_myPlotSide or G._wpMarkerPending then refreshMarkers(); G._wpMarkerPending = nil end
	local lastSide = G_myPlotSide
	do local _wt=0; RunService.Heartbeat:Connect(function()
		local now=tick(); if now-_wt < 1 then return end; _wt=now
		if G_myPlotSide ~= lastSide then lastSide = G_myPlotSide; refreshMarkers() end
	end) end
end

